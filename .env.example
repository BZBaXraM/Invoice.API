# Copy to .env and fill in the values before running `docker compose up`.

# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=InvoiceDb

# JWT (HmacSha512 requires a key of at least 64 characters)
JWT_SECRET=
# Optional; these defaults are baked into the compose files.
#JWT_ISSUER=Invoice.API
#JWT_AUDIENCE=Invoice.API
#JWT_EXPIRATION=120

# CORS
CORS_ORIGIN=http://localhost:4200

# Email (MailKit/SMTP)
EMAIL_FROM=
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=

# Admin seed account (created on first boot if no admin exists yet)
ADMIN_SEED_EMAIL=admin@invoice.com
ADMIN_SEED_PASSWORD=admin202210BK

# Groq (AI chat)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1/
